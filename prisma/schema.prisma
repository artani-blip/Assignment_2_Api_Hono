generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Snack {
  id        Int      @id @default(autoincrement())
  name      String
  stock     Int      @default(0)
  price     Float
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}